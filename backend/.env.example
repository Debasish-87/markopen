# ─── Server ───────────────────────────────────────────────────────────────────
ENV=production
PORT=8080

# ─── PostgreSQL (Supabase) ────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode pooler for serverless
DATABASE_URL=postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Individual fields (used if DATABASE_URL not set)
DB_HOST=aws-0-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.[PROJECT-REF]
DB_PASSWORD=your_supabase_db_password
DB_NAME=postgres
DB_SSLMODE=require

# ─── Redis (Upstash - free tier) ──────────────────────────────────────────────
# Get from: upstash.com → Create Database → REST URL
# Leave empty to disable Redis (rate limiting degrades gracefully)
REDIS_URL=redis://default:[PASSWORD]@[ENDPOINT]:PORT

# ─── Jaeger Tracing ───────────────────────────────────────────────────────────
# Leave empty on free tier — tracing is optional
JAEGER_ENDPOINT=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# MUST change — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRY_HOURS=24
USER_JWT_EXPIRY_HOURS=72

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# First boot creates this admin user — CHANGE THESE
ADMIN_SEED_USER=admin
ADMIN_SEED_PASS=CHANGE_ME_strong_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://markopen.in,https://www.markopen.in
